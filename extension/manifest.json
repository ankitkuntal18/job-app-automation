{
  "manifest_version": 3,
  "name": "LinkedIn Job Scraper",
  "version": "1.0",
  "description": "Extract job details from LinkedIn job posts with one click",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape LinkedIn Job"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"]
    }
  ]
}